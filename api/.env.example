# ──────────────────────────────────────────────────────────────
# AfroBoost API — environment variables
# Copy to .env and fill in. The app BOOTS WITHOUT any of these
# (clients init lazily); routes that hit a given service require
# its vars to be set.
# ──────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=3333

# ── Supabase (Phase 1+) ──────────────────────────────────────
# Project ref: ygmlgqtjvmswqooyxewg
SUPABASE_URL=https://ygmlgqtjvmswqooyxewg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# JWKS endpoint is derived from SUPABASE_URL; set this only if you
# verify HS256 legacy tokens instead of asymmetric JWTs.
SUPABASE_JWT_SECRET=

# ── Redis / BullMQ (Phase 0+) ────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Admin auth (Phase 2) ─────────────────────────────────────
ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=12h

# ── Prelude — phone OTP at signup (Phase 2) ──────────────────
PRELUDE_API_KEY=

# App URLs (used for OAuth/billing redirects)
APP_URL=https://app.afroboost.ca

# ── OpenAI — text + image generation (Phase 3) ───────────────
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# ── Stripe — billing (Phase 4) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs per plan (create in the Stripe dashboard)
STRIPE_PRICE_DECOUVERTE=
STRIPE_PRICE_PERFORMANCE=
STRIPE_PRICE_PREMIUM=
BILLING_SUCCESS_URL=
BILLING_CANCEL_URL=
BILLING_PORTAL_RETURN_URL=

# ── Meta / Facebook + Instagram (Phase 5) ────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_WEBHOOK_VERIFY_TOKEN=
# Facebook Login for Business configuration id. When set, the OAuth dialog uses
# config_id (system-user token) instead of a raw scope list.
META_LOGIN_CONFIG_ID=
# Where to send the mobile app back after connect (deep link). Defaults to
# afroboost://settings/accounts; set only to override the app scheme.
MOBILE_REDIRECT_URI=afroboost://settings/accounts

# ── Google (Business reviews + Gmail) (Phase 6) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── Microsoft (Outlook email) (Phase 6) ──────────────────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=
