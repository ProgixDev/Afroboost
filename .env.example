# Expo app env. Copy to .env.local and fill in.
# Only EXPO_PUBLIC_* vars are exposed to the client bundle — keep secrets out.
EXPO_PUBLIC_SUPABASE_URL=https://ygmlgqtjvmswqooyxewg.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# NestJS API base URL. Leave unset to run the app on local mock data (demo mode).
# Use your machine's LAN IP for a physical device, e.g. http://192.168.1.20:3333
EXPO_PUBLIC_API_URL=http://localhost:3333
